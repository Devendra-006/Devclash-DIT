# LLM backend: openrouter (default) or ollama (local)
LLM_PROVIDER=openrouter
# Optional: cap completion tokens for both backends
# LLM_MAX_TOKENS=4096

# --- OpenRouter (when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
# OpenRouter model id (default: openrouter/elephant-alpha)
OPENROUTER_MODEL=openrouter/elephant-alpha
# HTTP timeout in seconds for OpenRouter requests (default: 240)
OPENROUTER_TIMEOUT=240
# Set to 1 if OpenRouter hangs (broken system HTTP_PROXY / corporate proxy)
OPENROUTER_IGNORE_SYSTEM_PROXY=
# Optional: OpenRouter ranking / attribution
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=DevCareer
# --- Ollama (when LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:latest
# OLLAMA_TIMEOUT=600
# OLLAMA_MAX_TOKENS=4096
# OLLAMA_API_KEY=ollama

GITHUB_TOKEN=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
